# Copy to .env.local and fill in your values
# Never commit .env.local to git!

# Your FastAPI backend URL (no trailing slash)
# Local dev:       http://localhost:8000
# Deployed (Railway/Render/etc): https://your-api.up.railway.app
VITE_API_URL=http://localhost:8000

# ── Firebase (Web SDK config) ──────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# ── EmailJS (acknowledgement emails, free tier) ────────────────────────────
# Sign up at https://emailjs.com → create a service + template
# Template variables used: {{to_email}}, {{verdict}}, {{confidence}}, {{url}}, {{site}}
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
